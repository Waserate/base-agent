# Base Agent
# Copy this file to .env and fill in real values
# NEVER commit .env to git

# ── Wallet (active) ───────────────────────────────
WALLET_ADDRESS=0xYourWalletAddressHere
WALLET_PRIVATE_KEY=your_private_key_here

# ── Test Wallet ────────────────────────────────────
TEST_WALLET_ADDRESS=
TEST_WALLET_PRIVATE_KEY=

# ── RPC ───────────────────────────────────────────
BASE_RPC_URL=https://mainnet.base.org

# Pool discovery RPC (Multicall3 batch — high volume calls)
# Use Alchemy here to avoid 429. Leave blank to use BASE_RPC_URL.
DISCOVERY_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY

# ── Risk params ───────────────────────────────────
MIN_ETH_BALANCE=0.005        # stop agent if ETH < this (gas reserve)
MAX_POSITION_ETH=0.05        # max ETH per single action

# ── Scheduler ─────────────────────────────────────
RUN_HOUR=9                   # UTC hour to run daily (9 = 16:00 BKK)

# ── Dashboard PINs ────────────────────────────────
DASHBOARD_PIN=0000           # action PIN: add/reroll in dashboard
DASHBOARD_ADMIN_PIN=0000     # admin PIN: emergency close / withdraw

# ── Dry run ───────────────────────────────────────
DRY_RUN=false                # set true to simulate without sending TX
